# ─── Google AI Studio ───────────────────────────────────────────────
# Obtener en: https://aistudio.google.com → Get API Key
GOOGLE_API_KEY=tu_google_api_key_aqui

# ─── Qdrant Cloud ───────────────────────────────────────────────────
# Pedirle la clave a Diego — es compartida para todo el equipo
QDRANT_API_KEY=tu_qdrant_api_key_aqui
QDRANT_HOST=bbb61d2b-122f-4bd0-9837-d0c9c8e39b69.us-east4-0.gcp.cloud.qdrant.io
QDRANT_PORT=6333
QDRANT_COLLECTION=presupuestos_v1

# ─── Modelos ────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/gemini-embedding-001

# ─── Chunking ───────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ─── RAG ────────────────────────────────────────────────────────────
TOP_K_RESULTS=5

# ─── Gráficos ───────────────────────────────────────────────────────
# Opciones: conservador | moderado | agresivo
GRAFICO_AGRESIVIDAD=conservador
