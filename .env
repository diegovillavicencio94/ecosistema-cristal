GOOGLE_API_KEY=TU_LLAVE

# ─── Qdrant ─────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=presupuestos_v1

# ─── Modelos ────────────────────────────────────────────────────────
